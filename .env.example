# workspace-github-adapter environment example
# Copy this file to .env and adjust values for your environment.

# Required: PostgreSQL connection string used by adapter-service, adapter-worker, and migrations.
DATABASE_URL=postgres://workspace_adapter:workspace_adapter@localhost:5432/workspace_adapter?sslmode=disable

# Optional: HTTP port for adapter-service. Default: 8080
PORT=8080

# Optional: Redis/asynq queue connection URL.
# If empty, the app falls back to 127.0.0.1:6379 for local development.
REDIS_URL=redis://localhost:6379/0

# Required for GitHub API calls in real imports/syncs.
# Do not commit a real token. Put the real value in .env only.
GITHUB_TOKEN=replace-with-your-github-token

# Optional: Minutes after which a successful sync is considered stale. Default: 30
STALE_THRESHOLD_MINUTES=30
